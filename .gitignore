# .gitignore généré — couvre OS, IDEs, languages et outils courants

# System files
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
*~
*.swp
*.swo

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
yarn-error.log*

# Node.js
node_modules/
.npm/
.cache/
.next/
out/
dist/
build/
public/build/
.parcel-cache/
.eslintcache
*.tgz

# Package managers lock caches (keep lock files themselves by default)
.pnp.*
.pnpm-store/

# Environment / secrets
.env
.env.*
.env.local
secrets.yml
*.pem
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
htmlcov/
dist/
build/
*.egg-info/
.eggs/
venv/
.venv/
ENV/
env/
pip-log.txt

# Java / Maven / Gradle
target/
build/
*.class
*.jar
*.war
*.ear
*.iml

# PHP / Composer
vendor/
composer.lock

# Ruby / Rails
*.rbc
.bundle/
log/
tmp/
coverage/
.byebug_history

# Go
bin/
obj/
*.exe
*.test
vendor/

# Rust
target/

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace
*.tmproj
*.project
*.classpath

# JetBrains
*.iws
*.iml
*.ipr
out/

# JetBrains Rider/Resharper
_ReSharper*/
*.DotSettings.user

# Docker
docker-compose.override.yml
.docker/
**/docker-compose.override.yml

# CI / Build artifacts
coverage/
coverage-final.json
reports/
dist/
build/
release/
artifacts/

# Static site / frameworks
.svelte-kit/
.cache/
.nuxt/
.cypress/
.cypress_cache/

# Misc
bower_components/
jspm_packages/
*.bak
*.tmp
*.old
*.orig
*.rej

# OS lock / mount files
*.lock
*.pid
.idea_modules/

# Optional: ignore generated IDE workspace files
*.log
.history/

# Backend
# Ignore backend-specific files and folders
/backend/node_modules/
/backend/dist/
/backend/build/
/backend/.env
/backend/.env.*
/backend/.prisma/
/backend/prisma/dev.db
/backend/prisma/*.db
/backend/.next/
/backend/.cache/
/backend/.parcel-cache/
/backend/.turbo/
/backend/generated/prisma

# Frontend
# Logs
/frontend/logs
/frontend/*.log
/frontend/npm-debug.log*
/frontend/yarn-debug.log*
/frontend/yarn-error.log*
/frontend/pnpm-debug.log*
/frontend/lerna-debug.log*

/frontend/node_modules
/frontend/dist
/frontend/dist-ssr
/frontend/*.local

# Editor directories and files
/frontend/.vscode/*
/frontend/!.vscode/extensions.json
/frontend/.idea
/frontend/.DS_Store
/frontend/*.suo
/frontend/*.ntvs*
/frontend/*.njsproj
/frontend/*.sln
/frontend/*.sw?

# End